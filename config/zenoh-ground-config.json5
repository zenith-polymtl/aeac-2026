{  
  plugins: {  
    ros2dds: {  
      domain: 3,  
      ros_localhost_only: true,
      reliable_routes_blocking: false,  
      queries_timeout: {  
        default: 2.0  // Reduce from 5.0 seconds  
      },
      allow: {  
        publishers: [  
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"  
        ]  
      }  
    }  
  },  
  mode: "client",
  connect: {
    timeout_ms: -1,
    exit_on_failure: false,
    retry: {
      period_init_ms: 1000,
      period_max_ms: 4000,
      period_increase_factor: 2.0
    },
    endpoints: [
      "tcp/192.168.144.30:7447",
      "tcp/100.87.171.82:7447"
    ]
  },
  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false }
  }
}