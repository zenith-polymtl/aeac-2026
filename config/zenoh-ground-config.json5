{  
  plugins: {  
    ros2dds: {  
      domain: 3,  
      allow: {  
        publishers: [  
          "/tf",  
          "/tf_static",  
          "/zed/zed_node/rgb/color/rect/image/compressed",  
          "/zed/zed_node/mapping/fused_cloud",  
          "/zed/zed_node/rgb/color/rect/image/camera_info",  
          "/zed/zed_node/rgb/color/rect/camera_info",  
          "/zed/zed_node/status/heartbeat",  
          "/zed/zed_node/odom",
          "/chatter",  
          "/mavros.*"  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",  
          "/zed/zed_node/rgb/color/rect/image/compressed",  
          "/zed/zed_node/mapping/fused_cloud",  
          "/zed/zed_node/rgb/color/rect/image/camera_info",  
          "/zed/zed_node/rgb/color/rect/camera_info",  
          "/zed/zed_node/status/heartbeat",  
          "/zed/zed_node/odom",
          "/chatter",  
          "/mavros.*"  
        ]  
      }  
    }  
  },  
  mode: "peer",  
  connect: {  
    endpoints: [  
      "tcp/jetson-os.local:7447",  
      "tcp/192.168.0.12:7447"  
    ]  
  },  
  listen: {  
    endpoints: [  
      "tcp/0.0.0.0:7447"  
    ]  
  },  
scouting: {  
    multicast: {  
      enabled: true,  
      address: "224.0.0.224:7446",  
      interface: "auto",  
      autoconnect: { router: ["router"] },  // Changed from "router" to ["router"]  
      listen: true  
    },  
    gossip: {  
      enabled: true,  
      multihop: false,  
      autoconnect: { router: ["router"] }   // Changed from "router" to ["router"]  
    }  
  }
}