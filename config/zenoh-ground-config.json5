{  
  plugins: {  
    ros2dds: {  
      domain: 3,  
      ros_localhost_only: true,
      allow: {  
        publishers: [  
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"  
        ]  
      }  
    }  
  },  
  mode: "peer",  
  connect: {  
    endpoints: [  
      "tcp/100.87.171.82:7447",
      "tcp/192.168.144.30:7447",
    ]  
  },  
  listen: {  
    endpoints: [  
      "tcp/0.0.0.0:7447"  
    ]  
  },
  scouting: {  
    multicast: {  
      enabled: false  
    },  
    gossip: {  
      enabled: false  
    }  
  }
}