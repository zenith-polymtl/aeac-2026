{  
  plugins: {  
    ros2dds: {  
      domain: 2, 
      allow: {  
        publishers: [  
          "/tf",  
          "/tf_static",  
          "/chatter",  
          "/aeac/external.*"  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",
          "/zed/zed_node/status/heartbeat",
          "/zed/zed_node/obj_det/objects",
          "/chatter",  
          "/aeac/external.*"   
        ]  
      } 
    }  
  },  
  mode: "peer",  
  listen: {  
    endpoints: ["tcp/0.0.0.0:7447"]  
  }  
}