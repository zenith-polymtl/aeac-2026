{  
  plugins: {  
    ros2dds: {  
      domain: 2,  
      allow: {  
        publishers: [  
          "/tf",  
          "/tf_static",  
          "/zed/zed_node/rgb/color/rect/image/compressed",   
          "/zed/zed_node/rgb/color/rect/image/camera_info",  
          "/zed/zed_node/rgb/color/rect/camera_info",  
          "/zed/zed_node/status/heartbeat",  
          "/chatter",  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",  
          "/zed/zed_node/rgb/color/rect/image/compressed",   
          "/zed/zed_node/rgb/color/rect/image/camera_info",  
          "/zed/zed_node/rgb/color/rect/camera_info",  
          "/zed/zed_node/status/heartbeat",  
          "/chatter",  
        ]  
      }  
    }  
  },  
  mode: "peer",  
  listen: {  
    endpoints: ["tcp/0.0.0.0:7447"]  
  },  
  scouting: {  
    multicast: {  
      enabled: true,  
      address: "224.0.0.224:7446",  
      interface: "auto",  
      autoconnect: { router: ["router"] },  
      listen: true  
    },  
    gossip: {  
      enabled: true,  
      multihop: false,  
      autoconnect: { router: ["router"] }  
    }  
  }  
  scouting: {  
    multicast: {  
      enabled: true,  
      address: "224.0.0.224:7446",  
      interface: "auto",  
      autoconnect: { router: "router" },  
      listen: true  
    },  
    gossip: {  
      enabled: true,  
      multihop: false,  
      autoconnect: { router: "router" }  
    }  
  }  
}