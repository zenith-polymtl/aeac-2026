{  
  plugins: {  
    ros2dds: {  
      domain: 2, 
      ros_localhost_only: true,
      allow: {  
        publishers: [
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"  
        ],  
        subscribers: [  
          "/tf",  
          "/tf_static",
          "/chatter",  
          "/aeac/external.*"   
        ]  
      } 
    }  
  },
  mode: "router",
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"]
  },
  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false }
  }
}