[Unit]
Description=Payload (Docker Compose) - container lifecycle
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/home/zenith/aeac-2026

ExecStart=/usr/bin/docker compose -f compose/payload.yml up
ExecStop=/usr/bin/docker compose -f compose/payload.yml down

Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target